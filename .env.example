# Per-target bearer tokens (only used in local mode).
GITHUB_MCP_TOKEN=github_pat_xxx

# ADO config (required for both local and cloud).
ADO_ORG=krishnaroy
ADO_PROJECT=learn

# Local mode: leave ADO_MCP_TOKEN unset and `az login --tenant <tenant>` instead.
# Cloud mode: ALT injects ADO_MCP_TOKEN from Key Vault automatically.
# ADO_MCP_TOKEN=

# Optional Context7 API key (anonymous works without).
# CONTEXT7_API_KEY=

# Per-class VU counts. Sum MUST equal `users` in locust.conf.
GITHUB_USERS=2
LEARN_USERS=5
CONTEXT7_USERS=5
ADO_USERS=5

# Agent-shaped think time (defaults shown).
MCP_TURN_PROB=0.2
MCP_INTRA_MIN=0.1
MCP_INTRA_MAX=0.5
MCP_TURN_MIN=5
MCP_TURN_MAX=30
